{
	"$schema": "https://opencode.ai/config.json",
	"default_agent": "plan",
	"small_model": "anthropic/claude-haiku-4-5",
	"model": "anthropic/claude-sonnet-4-6",
	"agent": {
		"build": {
			"model": "anthropic/claude-sonnet-4-6",
			"variant": "high",
			"mode": "primary",
			"tools": {
				"write": true,
				"edit": true,
				"bash": true
			}
		},
		"plan": {
			"model": "anthropic/claude-haiku-4-5",
			"variant": "high",
			"mode": "primary",
			"tools": {
				"write": false,
				"edit": false,
				"bash": false
			}
		},
	},
	"disabled_providers": [
		"openai",
		"gemini"
	],
	"enabled_providers": [
		"anthropic"
	],
	"provider": {
		"anthropic": {
			"options": {
				"timeout": 600000,
				"setCacheKey": true
			},
			"models": {
				"claude-haiku-4-5": {
					"variants": {
						"low": {
							"disabled": true
						},
						"medium": {
							"disabled": true
						},
						"max": {
							"disabled": true
						}
					}
				},
				"claude-sonnet-4-6": {
					"variants": {
						"low": {
							"disabled": true
						},
						"medium": {
							"disabled": true
						},
						"max": {
							"disabled": true
						}
					}
				},
				"claude-opus-4-6": {
					"variants": {
						"low": {
							"disabled": true
						},
						"medium": {
							"disabled": true
						},
						"max": {
							"disabled": true
						}
					}
				}
			}
		},
	},
	"permission": {
		"bash": "ask",
		"read": "ask",
		"glob": "ask",
		"grep": "ask",
		"list": "ask",
		"edit": "ask"
	},
	"watcher": {
		"ignore": [
			"node_modules/**",
			".git/**",
			"dist/**",
			"build/**",
			"out/**",
			"output/**",
			".next/**",
			".astro/**",
			".remix/**",
			".cache/**",
			".turbo/**",
			".vercel/**",
			".netlify/**",
			".wrangler/**",
			"coverage/**",
			".nyc_output/**",
			"tmp/**",
			"temp/**",
			".tmp/**",
			"vendor/**",
			".parcel-cache/**",
			".vite/**",
			".svelte-kit/**",
			".nuxt/**",
			".output/**",
			"storybook-static/**",
			".storybook/static/**",
			".docusaurus/**",
			".contentlayer/**",
			"public/build/**",
			".env.*",
			"*.log",
			".DS_Store",
			"Thumbs.db",
			".idea/**",
			".vscode/**",
			"*.swp",
			"*.swo",
			".pnpm-store/**",
			".yarn/**",
			"playwright-report/**",
			"test-results/**",
			"cypress/videos/**",
			"cypress/screenshots/**",
			"__snapshots__/**",
			".terraform/**",
			".docker/**"
		]
	},
	"compaction": {
		"auto": true,
		"prune": true,
		"reserved": 10000
	},
	"autoupdate": true
}